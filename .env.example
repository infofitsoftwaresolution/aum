# ============================================================
# LOCAL DEVELOPMENT (.env file)
# ============================================================
# Copy this file to .env and fill in your values.
# This file is ONLY used for local development.
# On AWS Lambda, set these as Lambda Environment Variables
# via the AWS Console (never use .env on Lambda).
# ============================================================


# ── DEMO MODE ──────────────────────────────────────────────
# Set to true to run without PostgreSQL or Secrets Manager.
# Uses synthetic sample data. Only needs S3_BUCKET_NAME + AWS_REGION.
DEMO_MODE=false

# Required ONLY when DEMO_MODE=true — your S3 bucket name
S3_BUCKET_NAME=


# ── AWS SETTINGS ───────────────────────────────────────────
# AWS region for Secrets Manager + S3
AWS_REGION=ap-south-1

# Name of the secret in AWS Secrets Manager (not needed in demo mode)
AWS_SECRETS_NAME=aum-report-secrets

# AWS access keys — LOCAL DEV ONLY.
# On AWS Lambda: leave BLANK and use the Lambda IAM execution role instead.
# On EC2:        leave BLANK and use the EC2 instance IAM role instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ── LOCAL OUTPUT ───────────────────────────────────────────
# Local directory for generated Excel files (default: ./output)
# Ignored on Lambda — Lambda always writes to /tmp/aum_output
OUTPUT_DIR=output

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
